# Master local config for the 360PhotoBooth prototype.
#
# Copy this file to booth.env and edit booth.env. booth.env is gitignored
# because it can contain SMTP credentials.

# Backend FastAPI server.
BOOTH_HOST=0.0.0.0
BOOTH_PORT=8000
BOOTH_DATA=booth_backend/_data

# URL the phone should use to reach the backend. This must be the backend PC LAN
# address, not localhost. Update when switching networks.
BOOTH_BACKEND=http://10.6.14.178:8000

# Public URL inserted into result emails. Usually same as BOOTH_BACKEND.
PUBLIC_BASE_URL=http://10.6.14.178:8000

# ComfyUI API server used by the backend.
COMFY_URL=http://127.0.0.1:8188

# Workflow lookup. The backend loads ${WORKFLOW_DIR}/${WORKFLOW}.json.
WORKFLOW_DIR=booth_backend/workflows
WORKFLOW=native_video_invert

# Optional backend-side override. Useful when installed phone builds still send
# an older workflow name.
FORCE_WORKFLOW=native_video_invert

# Email delivery. Gmail requires an app password, not the normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=amdrad.team.2@gmail.com
SMTP_PASSWORD=
SMTP_FROM=amdrad.team.2@gmail.com
EMAIL_ATTACH_MAX_MB=22
